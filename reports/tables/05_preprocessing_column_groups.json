  "nominal_categorical_features": [
    "loan_category",
    "employment_type",
    "home",
    "is_verified"
  ],
  "ordinal_categorical_features": [
    "tier_of_employment",
    "work_experience",
    "income_band",
    "loan_amount_band",
    "interest_rate_band",
    "tenure_band",
    "loan_to_income_band"
