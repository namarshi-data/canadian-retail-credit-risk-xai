{
  "target": "defaulter",
  "id_columns": [
    "user_id",
    "record_sequence"
  ],
  "split_column": "split",
  "continuous_numeric_features": [
    "amount",
    "interest_rate",
    "tenure_years",
    "total_income_pa",
    "dependents",
    "loan_to_income_ratio",
    "broad_data_quality_issue_count",
